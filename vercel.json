{
  "version": 2,
  "installCommand": "pnpm install && prisma generate",
  "buildCommand": "prisma generate && nest build",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/main" }
  ],
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.ts",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    }
  ]
}