generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PRESIDENTE
  REDATOR
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  posts     Post[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  nome      String
  password  String
  bio       String?
  avatarUrl String?
  role      Role     @default(REDATOR)
  auditLogs  AuditLog[]
    tags      Tag[]    
  posts     Post[]
}

 
model Post {
  id        String   @id @default(uuid())
  titulo    String
  slug      String   @unique
  conteudo  String   @db.Text
  imagemUrl String
  imagemUrls String[] @default([])
  publicado Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  autorId   String
  autor     User     @relation(fields: [autorId], references: [id])
  tags      Tag[]
  likes     PostLike[]
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String?
  ip        String?
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@unique([postId, ip])
  @@index([postId])
}

model Management {
  id          String   @id @default(uuid())
  nome        String
  cargo       String
  descricao   String? 
  photoUrl    String?
  order       Int      @default(0) 
  isManagement Boolean @default(false)
  isSobre Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorEmail String
  actorRole  Role
  action     String
  entityType String
  entityId   String?
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entityType])
  @@index([action])
}