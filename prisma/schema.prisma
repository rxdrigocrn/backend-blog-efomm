generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PRESIDENTE
  REDATOR
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  posts     Post[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  nome      String
  password  String
  bio       String?
  avatarUrl String?
  role      Role     @default(REDATOR)
    tags      Tag[]    
  posts     Post[]
}

 
model Post {
  id        String   @id @default(uuid())
  titulo    String
  slug      String   @unique
  conteudo  String   @db.Text
  imagemUrl String
  imagemUrls String[] @default([])
  publicado Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  autorId   String
  autor     User     @relation(fields: [autorId], references: [id])
  tags      Tag[]
}

model Management {
  id          String   @id @default(uuid())
  nome        String
  cargo       String
  descricao   String? 
  photoUrl    String?
  order       Int      @default(0) 
  isManagement Boolean @default(false)
  isSobre Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}