generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PRESIDENTE
  REDATOR
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]   // Uma tag pode pertencer a vários usuários
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  nome      String
  password  String
  bio       String?
  avatarUrl String?
  role      Role     @default(REDATOR)
    tags      Tag[]    
  posts     Post[]
}

 
model Post {
  id        String   @id @default(uuid())
  titulo    String
  slug      String   @unique
  conteudo  String   @db.Text
  imagemUrl String
  publicado Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  autorId   String
  autor     User     @relation(fields: [autorId], references: [id])
}